# ──────────────────────────────────────────────────────────────────────────────
# مطعم خلدون — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Public URL and anon key are safe to expose client-side (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# SERVICE ROLE KEY — server-only. NEVER prefix with NEXT_PUBLIC_.
# Bypasses Row Level Security — used only in Server Actions and Route Handlers.
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_RESTAURANT_NAME=مطعم خلدون

# ── Cloudinary (Product Images) ──────────────────────────────────────────────
# Server-only — NEVER prefix with NEXT_PUBLIC_.
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# ── Vercel KV (Rate Limiting) ─────────────────────────────────────────────────
# Required for order rate limiting (T064). Get from Vercel KV dashboard.
KV_REST_API_URL=<your-kv-rest-api-url>
KV_REST_API_TOKEN=<your-kv-rest-api-token>
